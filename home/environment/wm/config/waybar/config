[{
    "exclusive": true,
    "passthrough": false,
    "position": "top",
    "reload_style_on_change": true,
    "gtk-layer-shell": true,
    "width": 1920,
    "height": 54,
    "layer": "top",
    /*"margin-top": 10,*/
    "mod": "dock",
"modules-left": [ "tray", "custom/padd-med", "custom/cpuicon", "cpu", "custom/padd-med", "custom/tempicon", "temperature", "custom/padd-med", "custom/memicon", "memory" ],
"modules-center": [ "custom/padd-med", "sway/workspaces", "custom/padd-med" ],
"modules-right": [ "custom/volumeicon", "pulseaudio", "custom/padd-med", "custom/networkicon", "network",  "custom/padd-med", "battery", "custom/batext", "custom/padd-med", "clock" ],

"backlight": {
      "device": "intel_backlight",
      "format": "{icon} {percent}%",
      "format-icons": [
        "п„Њ",
        "у°Єћ",
        "у°Єџ",
        "у°Є ",
        "у°ЄЎ",
        "у°Єў",
	"у°ЄЈ",
	"у°Є¤",
	"у°ЄҐ"
      ],
      "min-length": 6,
      "on-scroll-down": "brightnessctl set 1%-",
      "on-scroll-up": "brightnessctl set 1%+",
      "rotate": 0
    },
    "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{name}",
    "persistent_workspaces": {
        "1": [],
        "2": [],
        "3": []
    }
},

    "clock": {
      "actions": {
        "on-click-backward": "tz_down",
        "on-click-forward": "tz_up",
        "on-click-right": "mode",
        "on-scroll-down": "shift_down",
        "on-scroll-up": "shift_up"
      },
      "calendar": {
        "format": {
          "months": "<b>{}</b>",
          "today": "<b>{}</b>",
          "weekdays": "<b>{}</b>"
        },
        "mode": "month",
        "mode-mon-col": 3,
        "on-click-right": "mode",
        "on-scroll": 1
      },
      //"format": "пђє {:%H:%M:%S}",
      "format": "{:%A %I:%M %p}",
      "format-alt": "{:%a %d/%m}",
      "interval": 1,
      "rotate": 0,
      "tooltip-format": "<tt>{calendar}</tt>"
    },
    "cpu": {
      "format": " {usage}%",
      "interval": 1,
      "rotate": 0
    },
    "custom/cpuicon": {
      "format": "CPU"
    },
    "mpris": {
      "interval": 1,
      "max-length": 32,
    },
"custom/cavavis": {
	"exec": "$HOME/.local/bin/scripts/cava",
	"format": "{}",
},
"custom/memicon": {
	"format": "RAM"
},
    "memory": {
      "format": " {used}GB",
      "interval": 1,
      "max-length": 8,
      "min-length": 8,
      "rotate": 0,
      "tooltip": true,
      "tooltip-format": "у°ѕ† {percentage}%\nо‰¦ {used:0.1f}GB/{total:0.1f}GB"
    },
    
    "pulseaudio": {
      "format": " {volume}%",
      "on-click": "pavucontrol -t 3",
      "rotate": 0,
      "scroll-step": 5,
      "tooltip-format": "{icon} {desc} // {volume}%"
    },
    "custom/volumeicon": {
      "format": "Volume",
    },
    "pulseaudio#microphone": {
      "format": "{format_source}",
      "format-source": "п„° {volume}%",
      "format-source-muted": "п„±",
      "on-click": "pavucontrol -t 4",
      "rotate": 0,
      "scroll-step": 5,
      "tooltip-format": "{format_source} {source_volume}%"
    },
    "temperature": {
      "critical-threshold": 89,
      "format": " {temperatureC}В°C",
      "format-critical": "!!{temperatureC}В°C!!",
      "hwmon-path": [
        "/sys/class/thermal/thermal_zone3/temp",
        "/sys/class/thermal/thermal_zone5/temp"
      ],
      "interval": 1,
      "tooltip": true
    },
    "custom/tempicon": {
    	"format": "у°€ё"
    },

"custom/batext": {
  "exec": "cat /sys/class/power_supply/BAT0/capacity",
  "return-type": "text",
  "format": " {}%",
  "interval": 30
},

    "battery": {
      "format": "{icon}",
      "format-icons": [
        "у°‚Ћ",
        "у°Ѓє",
        "у°Ѓ»",
        "у°Ѓј",
        "у°ЃЅ",
        "у°Ѓѕ",
        "у°Ѓї",
        "у°‚Ђ",
        "у°‚Ѓ"
      ],
    },
    
    "bluetooth": {
      "format": "пЉ”",
      "format-connected": "у°‚±",
      "format-disabled": "у°‚І",
      "format-icons": [ "у°Ґ‡", "у°¤ѕ", "у°¤ї", "у°ҐЂ", "у°ҐЃ", "у°Ґ‚", "у°Ґѓ", "у°Ґ„", "у°Ґ…", "у°Ґ†", "у°Ґ€" ],
      "rotate": 0,
      "tooltip-format": "{controller_alias}\n{num_connections} connected",
      "tooltip-format-connected": "{device_enumerate}"
    },
    
    "custom/logo": {
      "format": "пЊѓ ",
      "on-click": "exec rofi -show drun"
    },
    "custom/power": {
      "format": "вЏ»",
      "on-click": "exec ~/.config/niri/scripts/session",
      "tooltip": false
    },
    "custom/swaync": {
      "escape": true,
      "exec": "swaync-client -swb",
      "exec-if": "which swaync-client",
      "format": "{icon}",
      "format-icons": {
        "dnd-inhibited-none": "у±Џ§",
        "dnd-inhibited-notification": "п‡·<span foreground='red'><sup>п‘„</sup></span>",
        "dnd-none": "у±Џ§",
        "dnd-notification": "у±Џ§<span foreground='red'><sup>п‘„</sup></span>",
        "inhibited-none": "у°‚љ",
        "inhibited-notification": "у°‚љ<span foreground='red'><sup>п‘„</sup></span>",
        "none": "у°‚љ",
        "notification": "у±…«"
      },
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "return-type": "json",
      "tooltip": false
    },
    "network": {
      "format-alt": " {essid} пЂ™ {bandwidthDownBytes:<1} п‚“ {bandwidthUpBytes:<1}",
      "format-disconnected": " у°–Є ",
      "format-ethernet": "у°€Ђ ",
      "format-linked": "у°€Ђ {ifname} (No IP)",
      "format-wifi": " {essid}",
      "interval": 1,
      "rotate": 0,
      "tooltip": true,
      "tooltip-format": "<span foreground='#86afef'>п‡«  {essid}:\nпЂ™ {bandwidthDownBytes}</span>\n<span foreground='#86afef'>п‚“ {bandwidthUpBytes}</span>"
    },
    "custom/networkicon": {
    	"format": "п‡« "
    },
    "tray": {
      "icon-size": 18,
      "rotate": 0,
      "spacing": 13 
    },
    "custom/padd": {
      "format": " ",
      "interval": "once",
      "tooltip": false
    },
    "custom/padd-med": {
      "format": "    ",
      "interval": "once",
      "tooltip": false
    },
    "custom/padd-big": {
      "format": "   ",
      "interval": "once",
      "tooltip": false
    },
},]
