#!/bin/sh

CONTAINER_NAME="nixenv"
REMOTE_DOCKERFILE="https://github.com/infraflakes/nixenv/raw/main/Dockerfile"

show_help() {
    echo "Usage: nixenv [create|start|build|help]"
    echo ""
    echo "Commands:"
    echo "  create   Provision a new dev environment"
    echo "  start    Attach to the container or exec into it if already active"
    echo "  build    Compile the remote OCI container specification"
    echo "  help     Display this system architecture matrix"
}

case "$1" in
    create)
        echo "Creating new container for dev environment: $CONTAINER_NAME... (っ´ω｀c)"
        podman run -it --network host --name "$CONTAINER_NAME" "$CONTAINER_NAME"
        ;;

    start)
        # Check if the container file node exists at all in the engine state
        if ! podman ps -a --format '{{.Names}}' | grep -Eq "^${CONTAINER_NAME}$"; then
            echo "Error: Container '$CONTAINER_NAME' does not exist yet. Run 'nixenv create' first! (っ´;ω;｀c)"
            exit 1
        fi

        # Inspect the running status of the container environment
        IS_RUNNING=$(podman inspect -f '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null)

        if [ "$IS_RUNNING" = "true" ]; then
            echo "Container is already active. Executing internal fish shell session... ~ ♡"
            podman exec -it "$CONTAINER_NAME" /usr/bin/fish
        else
            echo "Starting stopped container instance... (っ´>ω<｀c)"
            podman start -ai "$CONTAINER_NAME"
        fi
        ;;

    build)
        echo "Fetching and compiling remote OCI specification from GitHub..."
        podman build -t "$CONTAINER_NAME" "$REMOTE_DOCKERFILE"
        ;;

    help|--help|-h)
        show_help
        ;;

    *)
        echo "Error: Invalid command pattern '$1'."
        show_help
        exit 1
        ;;
esac
